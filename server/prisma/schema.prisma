generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model DashboardMonth {
  id        Int      @id @default(autoincrement())
  year      Int
  month     Int
  monthKey  String   @unique
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}