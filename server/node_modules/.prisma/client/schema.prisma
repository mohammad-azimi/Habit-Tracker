generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model DashboardMonth {
  id        Int      @id @default(autoincrement())
  userId    String
  year      Int
  month     Int
  monthKey  String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, monthKey])
}
